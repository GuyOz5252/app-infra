{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kafka": {
    "Producer": {
      "Example": {
        "BootstrapServers": "localhost:9092",
        "Topic": "orders",
        "Username": "app-example-producer",
        "Password": "local-dev-secret"
      }
    },
    "Consumers": {
      "Orders": {
        "BootstrapServers": "localhost:9092",
        "Topic": "orders",
        "Username": "app-orders-consumer",
        "Password": "local-dev-secret"
      },
      "Dashboard": {
        "BootstrapServers": "localhost:9092",
        "Topic": "dashboard",
        "Username": "app-dashboard-consumer",
        "Password": "local-dev-secret"
      }
    }
  }
}
