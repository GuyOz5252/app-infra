{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "MassTransit": "Information"
    }
  },
  "AllowedHosts": "*",
  "Kafka": {
    "Producers": {
      "Orders": {
        "BootstrapServers": "localhost:9092",
        "Topic": "mt-orders"
      },
      "Shipments": {
        "BootstrapServers": "localhost:9092",
        "Topic": "mt-shipments"
      }
    },
    "Consumers": {
      "Orders": {
        "BootstrapServers": "localhost:9092",
        "Topic": "mt-orders",
        "ConsumerGroup": "mt-sample-orders-group"
      },
      "Shipments": {
        "BootstrapServers": "localhost:9092",
        "Topic": "mt-shipments",
        "ConsumerGroup": "mt-sample-shipments-group"
      }
    }
  }
}
