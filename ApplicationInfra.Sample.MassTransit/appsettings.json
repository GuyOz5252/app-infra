{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "MassTransit": "Information"
    }
  },
  "AllowedHosts": "*",
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Topics": {
      "Orders": "mt-orders",
      "Shipments": "mt-shipments"
    },
    "ConsumerGroups": {
      "Orders": "mt-sample-orders-group",
      "Shipments": "mt-sample-shipments-group"
    }
  }
}
